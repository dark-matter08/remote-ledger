# The Remote Ledger — optional environment overrides.
# Everything here is OPTIONAL. Keys are normally set in the app (Settings → BYO keys,
# stored encrypted). Env vars override the encrypted store and are handy for CI/Docker.

# --- BYO API keys (only what you use) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=

# --- local model ---
# OLLAMA_URL=http://localhost:11434/v1

# --- storage overrides ---
# JOBS_DB_PATH=./data/jobs.db
# JOBS_MASTER_KEY=./data/.master.key   # path to the secrets master key

# --- server ---
# PORT=5173
