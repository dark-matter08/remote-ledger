{
  "manifest_version": 3,
  "name": "Remote Ledger Clipper",
  "version": "1.0.0",
  "description": "Clip a job posting to your local Remote Ledger in one click.",
  "permissions": ["tabs", "scripting", "activeTab", "storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "action": { "default_popup": "popup.html", "default_title": "Clip to Ledger" }
}
